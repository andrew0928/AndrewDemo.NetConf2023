@page "/"
@model AndrewDemo.NetConf2023.CommonStorefront.Pages.IndexModel
@{
    ViewData["Title"] = "首頁";
}
<section class="panel">
    <h1 class="page-heading">Andrew Shop Storefront</h1>
    <p>這是通用版 storefront 的 baseline implementation，提供商品瀏覽、購物車、結帳與會員查詢。</p>
    <div class="page-actions">
        <a class="button button--primary" href="/products">開始瀏覽商品</a>
        <a class="button button--secondary" href="/cart">查看購物車</a>
    </div>
</section>
