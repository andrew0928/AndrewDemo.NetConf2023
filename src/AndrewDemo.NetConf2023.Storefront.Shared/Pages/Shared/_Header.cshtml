@inject AndrewDemo.NetConf2023.Storefront.Shared.Authentication.StorefrontSessionAccessor SessionAccessor
<header class="site-header">
    <div class="site-header__container">
        <a class="site-header__brand" href="/">Andrew Shop</a>
        <nav aria-label="主要導覽">
            <ul class="site-nav">
                <li><a href="/">首頁</a></li>
                <li><a href="/products">商品列表</a></li>
                <li><a href="/cart">購物車</a></li>
                @if (SessionAccessor.HasAccessToken())
                {
                    <li><a href="/member">會員</a></li>
                    <li><a href="/member/orders">訂單</a></li>
                    <li><a href="/auth/logout">登出</a></li>
                }
                else
                {
                    <li><a href="/auth/login">登入</a></li>
                }
            </ul>
        </nav>
    </div>
</header>
