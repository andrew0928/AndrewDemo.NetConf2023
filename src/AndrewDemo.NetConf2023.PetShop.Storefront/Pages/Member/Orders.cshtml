@page "/member/orders"
@model AndrewDemo.NetConf2023.PetShop.Storefront.Pages.Member.OrdersModel
@{
    ViewData["Title"] = "訂單列表";
}
<section>
    <h1 class="page-heading">訂單列表</h1>
</section>

@if (Model.ErrorSummary.Errors.Count > 0)
{
    <partial name="_ErrorSummary" model="Model.ErrorSummary" />
}
else if (!Model.Orders.Any())
{
    <section class="panel">
        <p>目前沒有訂單。</p>
    </section>
}
else
{
    <section class="panel">
        <dl class="summary-list">
            <div class="summary-list__row">
                <dt>總訂單數</dt>
                <dd>@Model.TotalOrders</dd>
            </div>
            <div class="summary-list__row">
                <dt>總金額</dt>
                <dd>NT$ @Model.TotalAmount</dd>
            </div>
        </dl>
    </section>

    @foreach (var order in Model.Orders)
    {
        <section class="panel">
            <h2>訂單 #@order.Id</h2>
            <p>總額：NT$ @order.TotalPrice</p>
            <p>履約狀態：@order.FulfillmentStatus</p>
            <h3>商品明細</h3>
            <ul>
                @foreach (var line in order.ProductLines)
                {
                    <li>@line.ProductName x @line.Quantity - NT$ @line.LineAmount</li>
                }
            </ul>

            @if (order.DiscountLines.Any())
            {
                <h3>折扣明細</h3>
                <ul>
                    @foreach (var discount in order.DiscountLines)
                    {
                        <li>
                            <strong>@discount.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(discount.Description))
                            {
                                <span> - @discount.Description</span>
                            }
                            <span>（@(discount.Amount < 0 ? $"-NT$ {Math.Abs(discount.Amount)}" : $"NT$ {discount.Amount}")）</span>
                        </li>
                    }
                </ul>
            }
        </section>
    }
}
